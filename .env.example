# ─── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ─── Firebase Admin (Backend / Vercel only — NEVER expose to frontend) ───
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Legacy Data Migration (optional) ──────────────────────
# Set to your Firebase UID after first sign-up (Firebase Console → Authentication → Users)
LEGACY_MIGRATION_TARGET_UID=
# Set to "true" to auto-migrate legacy records on first authenticated API call
AUTO_MIGRATE_LEGACY=true

# ─── Firebase Client (Frontend — Vite requires VITE_ prefix) ───
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
